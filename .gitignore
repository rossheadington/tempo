# ---- Secrets & credentials (NEVER commit) ----
.env
.env.*
!.env.example
*.token
*.tokens
secrets/
credentials/
garmin_session/
.garminconnect/

# ---- Runtime data dir (DB, tokens, reports live here, outside the repo) ----
# Default location is ~/.tempo/ (outside the tree), but ignore any local copy too.
.tempo/

# ---- In-project content dir (plan, races, reports) — personal data, NEVER commit ----
# TEMPO_CONTENT_DIR points here so the markdown is handy alongside the code, but
# it holds health/training data and must stay out of this public repo.
training/

# ---- Personal health data (NEVER commit) ----
store/
data/
raw/
reports/
# Phase 12: telegram-bot launchd plist + run-daily plist write StandardOutPath
# /StandardErrorPath under <project>/logs/, and any other ad-hoc local logs
# belong here too. Never commit run logs -- they can echo transcripts, tokens,
# or other personal data.
logs/
# User-maintained context files live in the data dir (outside the tree); ignore
# any local copy in the repo root too, but keep the committed .example templates.
races.md
plan.md
!races.md.example
!plan.md.example
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.csv
*.fit
*.gpx
*.tcx

